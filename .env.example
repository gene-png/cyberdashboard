# Zero Trust Maturity Assessment Dashboard — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---- Flask core ----
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ---- Admin gate ----
# Generate with: python scripts/create_admin.py
ADMIN_PASSWORD_HASH=

# ---- Database ----
# SQLite path for local dev. On Azure App Service, mount persistent storage and
# point this at the mount path, e.g. sqlite:////home/data/assessments.db
DATABASE_URL=sqlite:///instance/assessments.db

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- SharePoint / Microsoft Graph ----
# From your Azure AD app registration (client credentials flow).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# From Graph Explorer: GET /sites/{hostname}:/sites/{siteName}
SHAREPOINT_SITE_ID=
# From Graph Explorer: GET /sites/{siteId}/drives
SHAREPOINT_DRIVE_ID=

# ---- Security ----
# Set to "true" on App Service (which terminates TLS and sets X-Forwarded-Proto)
FORCE_HTTPS=false
